---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title?: string;
  description?: string;
  /** Optional path override for canonical URL; defaults to Astro.url.pathname. */
  canonicalPath?: string;
  /** Optional OG image path (relative to site root). Defaults to /og-default.png. */
  ogImage?: string;
}

const {
  title = 'guitarserials.org — Decode any guitar serial number',
  description = 'A free, open-source guitar serial-number decoder. Gibson, Fender, PRS, Heritage, Sire, Ibanez — runs in your browser, offline.',
  canonicalPath,
  ogImage = '/og-default.png',
} = Astro.props;

const site = Astro.site ?? new URL('https://guitarserials.org');
const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, site).toString();
const absoluteOgImage = new URL(ogImage, site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="guitarserials.org" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <meta name="theme-color" content="#14100a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#faf6ec" media="(prefers-color-scheme: light)" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <script is:inline>
      (() => {
        const t = localStorage.getItem('theme');
        const pref = t === 'light' || t === 'dark'
          ? t
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', pref === 'dark');
      })();
    </script>

    <slot name="head" />
  </head>
  <body>
    <header class="border-b border-paper-line dark:border-espresso-line">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-5">
        <a
          href="/"
          class="group flex items-baseline gap-2 tracking-tight text-ink dark:text-cream"
        >
          <span class="display text-2xl font-semibold italic">guitarserials</span>
          <span class="text-sm text-ink-faint dark:text-cream-faint">.org</span>
        </a>
        <nav class="flex items-center gap-6 text-sm">
          <a
            href="/methodology"
            class="text-ink-soft hover:text-rust dark:text-cream-soft dark:hover:text-amber"
          >Methodology</a>
          <a
            href="/about"
            class="text-ink-soft hover:text-rust dark:text-cream-soft dark:hover:text-amber"
          >About</a>
          <ThemeToggle />
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-10">
      <slot />
    </main>

    <footer class="mt-20 border-t border-paper-line py-10 dark:border-espresso-line">
      <div class="mx-auto flex max-w-5xl flex-col gap-3 px-4 text-sm text-ink-soft md:flex-row md:items-baseline md:justify-between dark:text-cream-soft">
        <div class="flex flex-col gap-1">
          <p class="display italic text-base text-ink dark:text-cream">guitarserials.org</p>
          <p class="text-xs text-ink-faint dark:text-cream-faint">
            A reference for guitar serial numbers. Open source, MIT.
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs">
          <a href="/about" class="hover:text-rust dark:hover:text-amber">About</a>
          <a href="/methodology" class="hover:text-rust dark:hover:text-amber">Methodology</a>
          <a
            href="https://github.com/guitarserials/guitarserials"
            class="hover:text-rust dark:hover:text-amber"
          >Source</a>
          <span class="text-ink-faint dark:text-cream-faint">© 2026</span>
        </div>
      </div>
    </footer>
  </body>
</html>
