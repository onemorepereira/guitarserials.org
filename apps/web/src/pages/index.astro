---
import Decoder from '../components/Decoder';
import Base from '../layouts/Base.astro';
import { BRANDS } from '../lib/brands';

const brandCount = BRANDS.length;
const brandCountWord = [
  'zero',
  'one',
  'two',
  'three',
  'four',
  'five',
  'six',
  'seven',
  'eight',
  'nine',
  'ten',
  'eleven',
  'twelve',
  'thirteen',
  'fourteen',
  'fifteen',
  'sixteen',
  'seventeen',
  'eighteen',
  'nineteen',
  'twenty',
][brandCount] ?? String(brandCount);
const brandCountWordTitle = brandCountWord.charAt(0).toUpperCase() + brandCountWord.slice(1);

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'guitarserials.org',
  url: 'https://guitarserials.org/',
  description:
    'Free, open-source guitar serial-number decoder. Runs entirely in the browser.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://guitarserials.org/?s={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<Base>
  <script
    slot="head"
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(websiteJsonLd)}
  />

  <section class="flex flex-col gap-5 py-6">
    <h1 class="display text-5xl font-semibold leading-[1.05] text-ink md:text-6xl dark:text-cream">
      Paste a serial.<br />
      <span class="display-italic text-rust dark:text-amber">Read it back.</span>
    </h1>
    <p class="max-w-2xl text-lg text-ink-soft dark:text-cream-soft">
      Guitar serial numbers decoded — across {brandCount} makers and a century of manufacturing.
      Runs in your browser. Nothing leaves your device.
    </p>
  </section>

  <section class="rounded-lg border border-paper-line bg-paper-raised px-6 py-6 shadow-sm dark:border-espresso-line dark:bg-espresso-raised">
    <Decoder client:load />
  </section>

  <section class="mt-16 flex flex-col gap-5">
    <div class="flex items-baseline justify-between gap-4 border-b border-paper-line pb-3 dark:border-espresso-line">
      <h2 class="display text-3xl font-medium italic text-ink dark:text-cream">
        {brandCountWordTitle} makers.
      </h2>
      <p class="hidden text-sm text-ink-faint md:block dark:text-cream-faint">
        One click for the guide, conventions, and sources.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-x-8 gap-y-3 md:grid-cols-2">
      {
        BRANDS.map((brand) => (
          <a
            href={`/brands/${brand.slug}`}
            class="group flex items-baseline justify-between gap-4 border-b border-dashed border-paper-line py-3 transition hover:border-rust dark:border-espresso-line dark:hover:border-amber"
          >
            <span class="flex items-baseline gap-3">
              <span class="display text-xl font-medium text-ink group-hover:text-rust dark:text-cream dark:group-hover:text-amber">
                {brand.label}
              </span>
              <span class="text-rust opacity-0 transition group-hover:opacity-100 dark:text-amber">
                →
              </span>
            </span>
            <span class="text-right text-xs text-ink-faint dark:text-cream-faint">{brand.blurb}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mt-16 grid grid-cols-1 gap-6 md:grid-cols-3">
    <div>
      <h3 class="display text-lg font-semibold italic text-ink dark:text-cream">Built from sources</h3>
      <p class="mt-1 text-sm text-ink-soft dark:text-cream-soft">
        Every format rule traces back to at least two authoritative references — manufacturers
        where possible, then audited community references. See the{' '}
        <a href="/methodology" class="text-rust underline underline-offset-2 dark:text-amber">methodology</a>.
      </p>
    </div>
    <div>
      <h3 class="display text-lg font-semibold italic text-ink dark:text-cream">Runs offline</h3>
      <p class="mt-1 text-sm text-ink-soft dark:text-cream-soft">
        The decoder is a static site. No backend, no analytics, no account. Your serial never
        leaves the browser.
      </p>
    </div>
    <div>
      <h3 class="display text-lg font-semibold italic text-ink dark:text-cream">Got an incorrect decode?</h3>
      <p class="mt-1 text-sm text-ink-soft dark:text-cream-soft">
        This is an open-source community resource. Contributions with authoritative sources are
        welcome —{' '}
        <a
          href="https://github.com/guitarserials/guitarserials/issues/new?template=incorrect_decode.md"
          class="text-rust underline underline-offset-2 dark:text-amber"
        >open a report</a>.
      </p>
    </div>
  </section>
</Base>
