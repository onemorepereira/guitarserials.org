---
import { BRANDS } from '../../../lib/brands';

/**
 * The "where to find your serial" content has been inlined into the main
 * brand page under the `#find-serial` anchor. This page exists purely to
 * preserve the old URL — it emits a zero-second meta-refresh redirect to
 * the anchor so existing links, search-engine hits, and docs continue to
 * resolve.
 *
 * Astro still generates one static HTML per brand slug here.
 */

export function getStaticPaths() {
  return BRANDS.map((b) => ({ params: { brand: b.slug } }));
}

const { brand: slug } = Astro.params as { brand: string };
const brandMeta = BRANDS.find((b) => b.slug === slug);

if (!brandMeta) {
  return Astro.redirect('/404');
}

const canonical = `/brands/${brandMeta.slug}/#find-serial`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Redirecting — {brandMeta.label} serial location</title>
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${canonical}`} />
    <link rel="canonical" href={canonical} />
    <script is:inline define:vars={{ canonical }}>
      window.location.replace(canonical);
    </script>
  </head>
  <body>
    <p>
      Redirecting to <a href={canonical}>{canonical}</a>…
    </p>
  </body>
</html>
