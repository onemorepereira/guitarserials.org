{
  "name": "@guitarserials/core",
  "version": "0.1.0",
  "description": "Guitar serial-number decoder — pure TypeScript, zero runtime dependencies. Supports 18 brands across a century of production.",
  "license": "MIT",
  "author": "Miguel Pereira",
  "homepage": "https://guitarserials.org",
  "bugs": {
    "url": "https://github.com/guitarserials/guitarserials/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guitarserials/guitarserials.git",
    "directory": "packages/core"
  },
  "keywords": [
    "guitar",
    "serial",
    "serial-number",
    "decoder",
    "dating",
    "vintage",
    "gibson",
    "fender",
    "prs",
    "ibanez",
    "heritage",
    "sire",
    "martin",
    "rickenbacker",
    "gretsch",
    "jackson",
    "charvel",
    "epiphone",
    "squier",
    "gandl",
    "schecter",
    "esp",
    "ltd",
    "music-man"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
